# Copy to .env and fill in. NEVER commit the real .env.

# Single-user auth: the one long-lived device token the app sends as a Bearer token.
DEVICE_TOKEN=change-me-to-a-long-random-string

# Which AI provider backs reasoning. "claude_cli" now, "openai" later (drop-in).
AI_PROVIDER=claude_cli

# Path to the Claude CLI on the Ubuntu box (used by ClaudeCliProvider).
CLAUDE_CLI_PATH=claude

# OpenAI (used later by OpenAiProvider, and by Whisper/TTS if hosted).
OPENAI_API_KEY=

# Default user language for narration / answers: fa | en | nl
DEFAULT_LANG=en

# CORS: comma-separated origins allowed to call the gateway (the web app).
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
